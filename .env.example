# ─────────────────────────────────────────────────────────────────────────────
# Copie este arquivo para .env e preencha com seus valores reais
# NUNCA suba o arquivo .env pro GitHub — ele já está no .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Firebase — pegue no console do Firebase (Project Settings > General > Your apps)
VITE_FIREBASE_API_KEY=cole-aqui
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123:web:abc
ANTHROPIC_API_KEY=sk-ant-...
# Anthropic — pegue em console.anthropic.com
# Esta variável só vai no Netlify (não no .env local) — nunca no frontend!
ANTHROPIC_API_KEY=sk-ant-...
